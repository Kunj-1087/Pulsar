# Ably API Key (backend only)
ABLY_API_KEY=your_ably_api_key_here

# WebRTC & Signaling Configuration
NEXT_PUBLIC_STUN_SERVER=stun:stun.l.google.com:19302
NEXT_PUBLIC_SIGNALING_URL=/api/signal
NEXT_PUBLIC_MAX_FILE_SIZE_MB=100
NEXT_PUBLIC_CHUNK_SIZE_BYTES=16384
# SIGNALING SERVER
# The signaling server URL is now auto-detected at runtime from the page hostname.
# You do NOT need to set this manually. It is kept here for documentation only.
# ws://localhost:8080 is used when loading from localhost (host machine)
# ws://192.168.x.x:8080 is used automatically when loading from a LAN IP (joiner)
# NEXT_PUBLIC_SIGNALING_WS_URL=ws://localhost:8080

# TURN Configuration for firewall traversal (comma-separated URLs)
NEXT_PUBLIC_TURN_URL=turn:your_turn_server.com:3478?transport=udp,turn:your_turn_server.com:3478?transport=tcp
NEXT_PUBLIC_TURN_USERNAME=your_username
NEXT_PUBLIC_TURN_CREDENTIAL=your_password
# Optional: Set to true to force TURN relay during testing
NEXT_PUBLIC_FORCE_RELAY=false

# ========================================
# OFFLINE LAN MODE CONFIGURATION
# ========================================
# Set to "true" to enable Offline LAN Mode. When enabled:
# - No STUN, TURN, or Ably fallback are used
# - No external network requests are made
# - All connectivity is over the local network only
# - Default: "false" (online mode)
NEXT_PUBLIC_OFFLINE_MODE=false

# Signaling server port for offline mode. Must match SIGNALING_PORT on server.
# Default: 8080
NEXT_PUBLIC_SIGNALING_PORT=8080

# HTTPS mode for LAN deployment. When "true", uses wss:// for signaling.
# If not set, auto-detects from window.location.protocol.
# Only set this if auto-detection does not work in your environment.
# NEXT_PUBLIC_LAN_HTTPS=false

# Backend: Set to "true" on the signaling server to enable offline mode.
# This relaxes rate limiting for LAN-only deployments.
# Default: "false"
OFFLINE_MODE=false

# HTTPS Configuration (for offline:https mode only)
# Path to the TLS certificate file (PEM format)
HTTPS_ENABLED=false
TLS_CERT_PATH=./certs/lan-cert.pem
TLS_KEY_PATH=./certs/lan-key.pem

